  "qaContexts": [
    {
      "id": "qa-001",
      "library": "knowledge",
      "question": "肩袖损伤术后第 1 周是否可以主动外展？",
      "answer": "建议以被动和协助训练为主，主动外展需要根据疼痛和固定情况评估。"
    },
    {
      "id": "qa-002",
      "library": "motion",
      "question": "肩外展训练的推荐节奏是什么？",
      "answer": "建议每组 8-10 次，每次抬起后停顿 2 秒，组间休息 30 秒。"
    },
    {
      "id": "qa-003",
      "library": "voice",
      "question": "训练完成后应该返回哪类鼓励语？",
      "answer": "建议优先使用正向激励语气，并结合动作完成度和疼痛反馈动态调整措辞。"
    },
    {
      "id": "qa-004",
      "library": "sequence",
      "question": "肩袖术后第 1 周动作序列如何排序？",
      "answer": "建议先做肩胛稳定激活，再进行被动摆动，最后进入小范围肩外展训练。"
    }
  ]
